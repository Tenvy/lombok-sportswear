    "next": "16.1.6",
    "next-auth": "^4.24.14",
    "prisma": "^6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
