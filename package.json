{
  "name": "lombok-sportswear",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.9",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "bun --env-file=.env ./node_modules/.bin/prisma generate",
    "db:push": "bun --env-file=.env ./node_modules/.bin/prisma db push",
    "db:migrate": "bun --env-file=.env ./node_modules/.bin/prisma migrate dev",
    "db:seed": "bun --env-file=.env ./node_modules/.bin/prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "^6",
    "dotenv": "^17.2.3",
    "lucide-react": "^1.8.0",
    "next": "16.1.6",
    "next-auth": "^4.24.14",
    "prisma": "^6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.7.1",
    "typescript": "^5"
  }
}
